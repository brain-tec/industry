#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<span class=\"display-4-fs\"><strong>Vineyard</strong></span>"
msgstr "<span class=\"display-4-fs\"><strong>Виноградник</strong></span>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong><b>Appointments App</b>: </strong>Organize and book winery tours and "
"tastings, enhancing the visitor\n"
"                    experience."
msgstr ""
"<strong><b>Модуль Встречи</b>: </strong>Организуйте и бронируйте туры по "
"винодельне и дегустации, повышая качество обслуживания\n"
"                    посетителей."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong><b>CRM App</b>: </strong>Cultivate relationships with distributors "
"and private clients, tracking leads\n"
"                    to close more deals effectively.<br/>"
msgstr ""
"<strong><b>Модуль CRM</b>: </strong>Развивайте отношения с дистрибьюторами и "
"частными клиентами, отслеживая сделки\n"
"                    для эффективного роста продаж.<br/>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong><b>Field Service App</b>: </strong>Coordinate vineyard operations, "
"assigning tasks to teams for pruning,\n"
"                    spraying, and harvesting.<br/>"
msgstr ""
"<strong><b>Модуль Выездной сервис</b>: </strong>Координируйте работу на "
"виноградниках, назначая командам задачи по обрезке,\n"
"                    опрыскиванию и сбору урожая.<br/>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong><b>Manufacturing App</b>: </strong>Manage the art of winemaking by "
"overseeing pressing, fermentation,\n"
"                    and blending processes with precision.<br/>"
msgstr ""
"<strong><b>Модуль Производство</b>: </strong>Управляйте искусством "
"виноделия, контролируя процессы отжима, ферментации\n"
"                    и купажирования с высокой точностью.<br/>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong><b>PLM App</b>: </strong>Innovate your wine portfolio by iterating "
"on blend recipes and managing product\n"
"                    lifecycle changes.<br/>"
msgstr ""
"<strong><b>Модуль PLM</b>: </strong>Обновляйте свою винную карту, работая "
"над рецептами купажей и управляя\n"
"                    жизненным циклом продукта.<br/>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong><b>Point of Sale App</b>: </strong>Manage direct sales at the cellar "
"door with an easy-to-use interface\n"
"                    for visitors and tourists.<br/>"
msgstr ""
"<strong><b>Модуль POS</b>: </strong>Управляйте прямыми продажами в "
"дегустационном зале с помощью удобного интерфейса\n"
"                    для посетителей и туристов.<br/>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong><b>Quality App</b>: </strong>Ensure every bottle meets your "
"standards by tracking quality control points\n"
"                    throughout production.<br/>"
msgstr ""
"<strong><b>Модуль Качество</b>: </strong>Гарантируйте соответствие каждой "
"бутылки стандартам, отслеживая точки контроля качества\n"
"                    на протяжении всего производства.<br/>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong><b>Website App</b>: </strong>Sell your wines globally with a fully "
"integrated eCommerce platform that\n"
"                    manages inventory in real-time.<br/>"
msgstr ""
"<strong><b>Модуль Вебсайт</b>: </strong>Продавайте свои вина по всему миру с "
"помощью полностью интегрированной платформы электронной коммерции,\n"
"                    управляющей складом в реальном времени.<br/>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Accept multiple payment methods</strong> (cash, card)."
msgstr "<strong>Принимайте несколько методов оплаты</strong> (наличные, карта)."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong>Accounting</strong> – Manage finances, track profitability by "
"product line, and automate reporting."
msgstr ""
"<strong>Бухгалтерия</strong> – Управляйте финансами, отслеживайте "
"прибыльность по линейкам продуктов и автоматизируйте отчетность."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Add products</strong> to POS catalog."
msgstr "<strong>Добавляйте продукты</strong> в каталог POS."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Analyze trends</strong> for planning through reporting."
msgstr ""
"<strong>Анализируйте тренды</strong> для планирования на основе отчетности."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Apply taxes</strong> automatically on invoices."
msgstr "<strong>Автоматически применяйте налоги</strong> в счетах."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Appointments 📅</strong>"
msgstr "<strong>Встречи 📅</strong>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Approve only if tests pass</strong>."
msgstr ""
"<strong>Утверждайте только в случае успешного прохождения тестов</strong>."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Assign checks</strong> to manufacturing steps."
msgstr "<strong>Назначайте проверки</strong> на этапы производства."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Assign lot numbers</strong> to batches."
msgstr "<strong>Присваивайте партиям номера</strong>."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Assign to workers</strong> or external partners."
msgstr "<strong>Назначайте сотрудников</strong> или внешних партнеров."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Attach related quality points</strong> to ECO."
msgstr ""
"<strong>Прикрепите соответствующие контрольные точки</strong> к изменению в "
"производственном заказе."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Basics</strong>"
msgstr "<strong>Основы</strong>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>CRM 🎯</strong>"
msgstr "<strong>CRM 🎯</strong>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Capture leads</strong> from website forms or direct outreach."
msgstr ""
"<strong>Собирайте лиды</strong> с веб-форм или через прямое взаимодействие."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong>Collaborate internally</strong> through chatter notes and file "
"attachments."
msgstr ""
"<strong>Сотрудничайте внутри команды</strong> через заметки в чате и "
"вложения файлов."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Compare scrap over time</strong> to measure progress."
msgstr ""
"<strong>Сравнивайте отходы с течением времени</strong>, чтобы измерить "
"прогресс."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Compare yield ratios</strong> to expectations."
msgstr ""
"<strong>Сравнивайте коэффициенты урожайности</strong> с ожидаемыми "
"значениями."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Configure excise rates</strong> in products."
msgstr "<strong>Настраивайте ставки акцизов</strong> в карточках товаров."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong>Create appointment types</strong> (e.g., tour &amp; tasting, private "
"tour)."
msgstr ""
"<strong>Создавайте типы встреч</strong> (например, тур и дегустация, частный "
"тур)."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Create engineering change orders</strong> in PLM."
msgstr ""
"<strong>Создавайте изменения в производственных заказах</strong> в модуле "
"PLM."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong>Create manufacturing orders</strong> for specific grapes, musts and "
"assemblages."
msgstr ""
"<strong>Создавайте производственные заказы</strong> для конкретного "
"винограда, сусла и купажей."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong>Create product pages</strong> with tasting notes and vintage details."
msgstr ""
"<strong>Создавайте страницы продуктов</strong> с дегустационными заметками и "
"информацией о годе урожая."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Create tasks</strong> with location, date, and description."
msgstr "<strong>Создавайте задачи</strong> с указанием места, даты и описания."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong>Define bills of materials</strong> with grape types and quantities."
msgstr ""
"<strong>Определяйте спецификации</strong> с указанием сортов винограда и "
"количества."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong>Define quality control points</strong> (acidity, sugar content, "
"clarity)."
msgstr ""
"<strong>Определяйте точки контроля качества</strong> (кислотность, "
"содержание сахара, прозрачность)."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Detailed usage:</strong>"
msgstr "<strong>Детальное описание использования:</strong>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Do You Want to Go Further?</strong>"
msgstr "<strong>Хотите узнать больше?</strong>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Enable online payments</strong> and automated invoicing."
msgstr ""
"<strong>Включите онлайн-платежи</strong> и автоматическое выставление счетов."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong>Events</strong> – Organize wine festivals, promotional events, or "
"launch parties."
msgstr ""
"<strong>Мероприятия</strong> – организуйте винные фестивали, рекламные акции "
"или вечеринки в честь запуска новых вин."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Excise Management 💰</strong>"
msgstr "<strong>Управление акцизами 💰</strong>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Field Service 🚜</strong>"
msgstr "<strong>Выездной сервис 🚜</strong>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Follow up </strong>your plan from the planning"
msgstr "<strong>Отслеживайте</strong> ваш план из модуля Планирование"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Generate excise reports</strong> for submission."
msgstr "<strong>Формируйте отчеты по акцизам</strong> для подачи."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Generate lot numbers</strong> for traceability."
msgstr "<strong>Генерируйте номера партий</strong> для прослеживаемости."

#. module: vineyard
#: model_terms:product.template,description:vineyard.product_product_16_product_template
#: model_terms:product.template,description:vineyard.product_product_25_product_template
#: model_terms:product.template,description:vineyard.product_product_26_product_template
#: model_terms:product.template,description:vineyard.product_product_27_product_template
msgid ""
"<strong>Goal</strong>: Aromatic complexity, age-worthiness, firm tannins"
msgstr ""
"<strong>Цель</strong>: Ароматная сложность, потенциал к выдержке, плотные "
"танины"

#. module: vineyard
#: model_terms:product.template,description:vineyard.product_product_17_product_template
msgid "<strong>Goal</strong>: Deep color, spice, aging potential"
msgstr "<strong>Цель</strong>: Глубокий цвет, пряность, потенциал выдержки"

#. module: vineyard
#: model_terms:product.template,description:vineyard.product_product_15_product_template
msgid "<strong>Goal</strong>: Round mouthfeel, fruit-forward, soft tannins"
msgstr "<strong>Цель</strong>: Мягкое, фруктовое, с бархатистыми танинами"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Harvest Management 🌾</strong>"
msgstr "<strong>Управление сбором урожая 🌾</strong>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.ir_ui_view_4048
msgid ""
"<strong>Includes:</strong> Vineyard walk, cellar visit, guided tasting of 3 "
"wines"
msgstr ""
"<strong>Что входит:</strong> Прогулка по винограднику, посещение погреба, "
"дегустация 3 вин с гидом"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong>Integrate your apps</strong> so sales, production, and quality data "
"flow seamlessly."
msgstr ""
"<strong>Интегрируйте ваши модули</strong>, чтобы данные о продажах, "
"производстве и качестве передавались без сбоев."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.ir_ui_view_4048
msgid "<strong>Languages:</strong> EN / CH / FR"
msgstr "<strong>Языки:</strong> EN / CH / FR"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Log grape harvests</strong> in Inventory."
msgstr "<strong>Регистрируйте сбор урожая винограда</strong> в модуле Склад."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Log results</strong> for each lot."
msgstr "<strong>Ведите учет результатов</strong> для каждой партии."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Log time and materials</strong> used."
msgstr "<strong>Учитывайте время и материалы</strong>, использованные в работе."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Manufacturing 🛠</strong>"
msgstr "<strong>Производство 🛠</strong>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Mark complete</strong> once the work is done."
msgstr "По завершении работы отметьте задачу как <strong>выполненную</strong>."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Monitor yields</strong> and scrap quantities."
msgstr "<strong>Контролируйте урожайность</strong> и количество отходов."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong>Move opportunities</strong> across pipeline stages until closing."
msgstr ""
"<strong>Перемещайте возможности</strong> по этапам воронки продаж до "
"закрытия сделки."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>PLM 🧪</strong>"
msgstr "<strong>PLM 🧪</strong>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Point of Sale 🏷</strong>"
msgstr "<strong>POS 🏷</strong>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Prepare guest experiences</strong> based on booking notes."
msgstr ""
"<strong>Создавайте персональный гостевой опыт</strong> согласно запросам при "
"бронировании."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Print or email receipts</strong>."
msgstr "<strong>Печатайте или отправляйте чеки по электронной почте</strong>."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Promote offers</strong> through banners and newsletters."
msgstr "<strong>Продвигайте предложения</strong> через баннеры и рассылки."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Publish booking links</strong> on your website."
msgstr "<strong>Публикуйте ссылки для бронирования</strong> на вашем сайте."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong>Qualify prospects</strong> by checking interest level, wine "
"preferences, and budget."
msgstr ""
"<strong>Квалифицируйте потенциальных клиентов</strong>, проверяя уровень "
"интереса, винные предпочтения и бюджет."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Quality ✅</strong>"
msgstr "<strong>Качество ✅</strong>"

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid "<strong>Receive notifications</strong> for new bookings."
msgstr "<strong>Получайте уведомления</strong> о новых бронированиях."

#. module: vineyard
#: model_terms:ir.ui.view,arch_db:vineyard.welcome_article_body
msgid ""
"<strong>Record production steps</strong> such as fermentation and blending."
msgstr ""
"<strong>Записывайте этапы производства</strong>, такие как брожение и "
"купажирование."

#. module: vineyard
